rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userExists(uid) {
      return exists(/databases/$(database)/documents/users/$(uid));
    }
    
    function hasRole(role) {
      return isAuthenticated() && userExists(request.auth.uid) && getUserData().role == role;
    }

    function isAdmin() {
      return hasRole('admin') || 
             (isAuthenticated() && request.auth.token.email == "autoaidc6@gmail.com" && request.auth.token.email_verified == true);
    }
    
    function isParent() {
      return hasRole('parent');
    }

    function isParentOf(studentData) {
      return isParent() && studentData.parentUid == request.auth.uid;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.email is string && data.email.size() > 0 &&
             data.role in ['parent', 'student', 'admin'] &&
             (!('name' in data) || (data.name is string && data.name.size() < 100)) &&
             (!('username' in data) || (data.username is string && data.username.size() < 50)) &&
             (!('parentUid' in data) || (data.parentUid is string && data.parentUid.size() > 0)) &&
             (!('yearGroup' in data) || (data.yearGroup is string && data.yearGroup.size() < 20)) &&
             (!('birthMonth' in data) || (data.birthMonth is number && data.birthMonth >= 1 && data.birthMonth <= 12)) &&
             (!('birthYear' in data) || (data.birthYear is number && data.birthYear >= 1900)) &&
             (!('school' in data) || (data.school is string && data.school.size() < 200)) &&
             (!('recommenderEnabled' in data) || (data.recommenderEnabled is bool)) &&
             (!('selfAssignEnabled' in data) || (data.selfAssignEnabled is bool)) &&
             (!('setupToken' in data) || (data.setupToken is string)) &&
             (!('points' in data) || (data.points is number && data.points >= 0));
    }

    function isValidScore(data) {
      return data.keys().hasAll(['id', 'userUid', 'activityId', 'score', 'completedAt']) &&
             data.id is string &&
             data.userUid is string &&
             data.activityId is string &&
             data.score is number && data.score >= 0 && data.score <= 100 &&
             data.completedAt is string &&
             (!('parentUid' in data) || (data.parentUid is string && data.parentUid.size() > 0));
    }

    function isValidReward(data) {
      return data.keys().hasAll(['id', 'parentUid', 'studentUid', 'category', 'description', 'pointsRequired', 'status']) &&
             data.id is string &&
             data.parentUid is string &&
             data.studentUid is string &&
             data.category is string &&
             data.description is string && data.description.size() < 500 &&
             data.pointsRequired is number && data.pointsRequired > 0 &&
             data.status in ['in-progress', 'achieved', 'claimed'];
    }

    function isValidAssignment(data) {
      return data.keys().hasAll(['parentUid', 'studentUid', 'activityId', 'activityTitle', 'subject', 'status', 'assignedAt']) &&
             data.parentUid is string &&
             data.studentUid is string &&
             data.activityId is string &&
             data.activityTitle is string &&
             data.subject is string &&
             data.status in ['pending', 'in-progress', 'completed'] &&
             data.assignedAt is string &&
             (!('id' in data) || data.id is string);
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /users/{uid} {
      allow get: if isOwner(uid) || isAdmin() || (isParent() && resource.data.parentUid == request.auth.uid);
      allow list: if isAdmin() || (isParent() && resource.data.parentUid == request.auth.uid) || (resource.data.setupToken != null);
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    (isOwner(uid) || isAdmin() || (isParent() && request.resource.data.parentUid == request.auth.uid));
      allow update: if (isOwner(uid) || isAdmin()) && isValidUser(request.resource.data) && 
                    (isAdmin() || request.resource.data.role == resource.data.role);
    }
    
    match /activities/{id} {
      allow get: if isAuthenticated();
      allow list: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /scores/{id} {
      allow get: if isAuthenticated() && (isOwner(resource.data.userUid) || (isParent() && resource.data.parentUid == request.auth.uid) || isAdmin());
      allow list: if isAuthenticated() && (isOwner(resource.data.userUid) || (isParent() && resource.data.parentUid == request.auth.uid) || isAdmin());
      allow create: if isAuthenticated() && isValidScore(request.resource.data) && (isOwner(request.resource.data.userUid) || isAdmin());
      allow update: if isAdmin();
    }
    
    match /rewards/{id} {
      allow get: if isAuthenticated() && (isOwner(resource.data.parentUid) || isOwner(resource.data.studentUid) || isAdmin());
      allow list: if isAuthenticated() && (isOwner(resource.data.parentUid) || isOwner(resource.data.studentUid) || isAdmin());
      allow create: if isAuthenticated() && isValidReward(request.resource.data) && (isOwner(request.resource.data.parentUid) || isAdmin());
      allow update: if isAuthenticated() && isValidReward(request.resource.data) && (isOwner(request.resource.data.parentUid) || isOwner(resource.data.studentUid) || isAdmin());
    }

    match /assignments/{id} {
      allow get: if isAuthenticated() && (request.auth.uid == resource.data.parentUid || request.auth.uid == resource.data.studentUid || isAdmin());
      allow list: if isAuthenticated() && (request.auth.uid == resource.data.parentUid || request.auth.uid == resource.data.studentUid || isAdmin());
      allow create: if isAuthenticated() && (request.auth.uid == request.resource.data.parentUid || isAdmin());
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.parentUid || request.auth.uid == resource.data.studentUid || isAdmin());
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.parentUid || isAdmin());
    }
  }
}
